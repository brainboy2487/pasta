# test_shapes.ps — draws triangle, circle, rectangle in a window

w = WINDOW("pasta shapes", 400, 300)
c = CANVAS(400, 300)

# black background
y = 0
while y < 300:
  x = 0
  while x < 400:
    PIXEL(c, x, y, 0, 0, 0)
    x = x + 1
  y = y + 1

# filled red rectangle (x=20, y=20, w=100, h=80)
y = 20
while y < 100:
  x = 20
  while x < 120:
    PIXEL(c, x, y, 220, 50, 50)
    x = x + 1
  y = y + 1

# green circle (cx=250, cy=100, r=60) — midpoint algorithm
cx = 250
cy = 100
r = 60
px = r
py = 0
err = 0
while px >= py:
  PIXEL(c, cx+px, cy+py, 50, 220, 50)
  PIXEL(c, cx+py, cy+px, 50, 220, 50)
  PIXEL(c, cx-py, cy+px, 50, 220, 50)
  PIXEL(c, cx-px, cy+py, 50, 220, 50)
  PIXEL(c, cx-px, cy-py, 50, 220, 50)
  PIXEL(c, cx-py, cy-px, 50, 220, 50)
  PIXEL(c, cx+py, cy-px, 50, 220, 50)
  PIXEL(c, cx+px, cy-py, 50, 220, 50)
  py = py + 1
  if err <= 0:
    err = err + (py + py + 1)
  if err > 0:
    px = px - 1
    err = err + (1 - px - px)

# blue triangle (outline using Bresenham lines)
# vertices: (50,250), (150,150), (250,250)
# line 1: (50,250) -> (150,150)
x0 = 50
y0 = 250
x1 = 150
y1 = 150
dx = x1 - x0
dy = y1 - y0
if dx < 0:
  dx = 0 - dx
if dy < 0:
  dy = 0 - dy
sx = 1
if x0 > x1:
  sx = 0 - 1
sy = 1
if y0 > y1:
  sy = 0 - 1
lerr = dx - dy
lx = x0
ly = y0
running = 1
while running == 1:
  PIXEL(c, lx, ly, 50, 100, 220)
  if lx == x1:
    if ly == y1:
      running = 0
  e2 = lerr + lerr
  if e2 > (0 - dy):
    lerr = lerr - dy
    lx = lx + sx
  if e2 < dx:
    lerr = lerr + dx
    ly = ly + sy

# line 2: (150,150) -> (250,250)
x0 = 150
y0 = 150
x1 = 250
y1 = 250
dx = x1 - x0
dy = y1 - y0
if dx < 0:
  dx = 0 - dx
if dy < 0:
  dy = 0 - dy
sx = 1
if x0 > x1:
  sx = 0 - 1
sy = 1
if y0 > y1:
  sy = 0 - 1
lerr = dx - dy
lx = x0
ly = y0
running = 1
while running == 1:
  PIXEL(c, lx, ly, 50, 100, 220)
  if lx == x1:
    if ly == y1:
      running = 0
  e2 = lerr + lerr
  if e2 > (0 - dy):
    lerr = lerr - dy
    lx = lx + sx
  if e2 < dx:
    lerr = lerr + dx
    ly = ly + sy

# line 3: (250,250) -> (50,250)
x0 = 250
y0 = 250
x1 = 50
y1 = 250
dx = x1 - x0
dy = y1 - y0
if dx < 0:
  dx = 0 - dx
if dy < 0:
  dy = 0 - dy
sx = 1
if x0 > x1:
  sx = 0 - 1
sy = 1
if y0 > y1:
  sy = 0 - 1
lerr = dx - dy
lx = x0
ly = y0
running = 1
while running == 1:
  PIXEL(c, lx, ly, 50, 100, 220)
  if lx == x1:
    if ly == y1:
      running = 0
  e2 = lerr + lerr
  if e2 > (0 - dy):
    lerr = lerr - dy
    lx = lx + sx
  if e2 < dx:
    lerr = lerr + dx
    ly = ly + sy

# white border rectangle outline
y = 10
while y < 290:
  PIXEL(c, 10, y, 255, 255, 255)
  PIXEL(c, 389, y, 255, 255, 255)
  y = y + 1
x = 10
while x < 390:
  PIXEL(c, x, 10, 255, 255, 255)
  PIXEL(c, x, 289, 255, 255, 255)
  x = x + 1

BLIT(w, c)
WINDOW_SAVE(w, "shapes.ppm")

# keep window open until closed
while WINDOW_OPEN(w):
  BLIT(w, c)

CLOSE(w)
