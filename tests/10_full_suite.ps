# ================================================================
# 10_full_suite.ps — PASTA Full Feature Test Suite
# 50 sections covering all language features.
# Expected outputs marked with  # =>
# ================================================================


# ════════════════════════════════════════════════════════════════
# SECTION 1: Literals and basic print
# ════════════════════════════════════════════════════════════════
PRINT "=== SECTION 1: Literals ==="

PRINT 42                         # => 42
PRINT 3.14                       # => 3.14
PRINT true                       # => true
PRINT false                      # => false
PRINT "pasta"                    # => pasta
PRINT 0                          # => 0
PRINT -1                         # => -1


# ════════════════════════════════════════════════════════════════
# SECTION 2: Arithmetic operators
# ════════════════════════════════════════════════════════════════
PRINT "=== SECTION 2: Arithmetic ==="

PRINT 2 + 3                      # => 5
PRINT 10 - 4                     # => 6
PRINT 3 * 7                      # => 21
PRINT 15 / 4                     # => 3.75
PRINT 17 % 5                     # => 2
PRINT 2 ^ 8                      # => 256
PRINT 1 + 2 * 3                  # => 7
PRINT (1 + 2) * 3                # => 9
PRINT 100 / 10 / 2               # => 5
PRINT 2 ^ 3 ^ 2                  # => 512


# ════════════════════════════════════════════════════════════════
# SECTION 3: Variable assignment and rebinding
# ════════════════════════════════════════════════════════════════
PRINT "=== SECTION 3: Variables ==="

a = 5
b = 10
PRINT a                          # => 5
PRINT b                          # => 10
PRINT a + b                      # => 15
a = a * 2
PRINT a                          # => 10
b = b - 3
PRINT b                          # => 7
PRINT a + b                      # => 17


# ════════════════════════════════════════════════════════════════
# SECTION 4: String operations
# ════════════════════════════════════════════════════════════════
PRINT "=== SECTION 4: Strings ==="

s = "hello"
PRINT len(s)                     # => 5
PRINT upper(s)                   # => HELLO
PRINT lower("WORLD")             # => world
PRINT concat(s, " world")        # => hello world
PRINT s[0]                       # => h
PRINT s[-1]                      # => o
PRINT trim("  hi  ")             # => hi
PRINT starts_with("pasta", "pas") # => true
PRINT ends_with("pasta", "sta")  # => true
PRINT replace("hello", "l", "r") # => herro
parts = split("a,b,c", ",")
PRINT list_first(parts)          # => a
PRINT list_last(parts)           # => c


# ════════════════════════════════════════════════════════════════
# SECTION 5: Boolean logic
# ════════════════════════════════════════════════════════════════
PRINT "=== SECTION 5: Boolean Logic ==="

PRINT true && true               # => true
PRINT true && false              # => false
PRINT false || true              # => true
PRINT false || false             # => false
PRINT NOT true                   # => false
PRINT NOT false                  # => true
PRINT (1 < 2) && (3 < 4)        # => true
PRINT (1 > 2) || (3 < 4)        # => true
PRINT NOT (1 == 2)               # => true


# ════════════════════════════════════════════════════════════════
# SECTION 6: Comparison operators
# ════════════════════════════════════════════════════════════════
PRINT "=== SECTION 6: Comparisons ==="

PRINT 1 == 1                     # => true
PRINT 1 == 2                     # => false
PRINT 1 != 2                     # => true
PRINT 5 > 3                      # => true
PRINT 5 < 3                      # => false
PRINT 5 >= 5                     # => true
PRINT 5 <= 4                     # => false
PRINT "abc" == "abc"             # => true
PRINT "abc" != "def"             # => true


# ════════════════════════════════════════════════════════════════
# SECTION 7: IF / OTHERWISE
# ════════════════════════════════════════════════════════════════
PRINT "=== SECTION 7: IF/OTHERWISE ==="

x = 10
IF x > 5:
    PRINT "big"
OTHERWISE:
    PRINT "small"
END
# => big

IF x == 10:
    PRINT "ten"
END
# => ten

IF x < 0:
    PRINT "negative"
OTHERWISE:
    IF x == 0:
        PRINT "zero"
    OTHERWISE:
        PRINT "positive"
    END
END
# => positive


# ════════════════════════════════════════════════════════════════
# SECTION 8: WHILE loops
# ════════════════════════════════════════════════════════════════
PRINT "=== SECTION 8: WHILE ==="

i = 0
DO WHILE i < 5:
    PRINT i
    i = i + 1
END
# => 0 1 2 3 4

total = 0
n = 1
WHILE n <= 10:
    total = total + n
    n = n + 1
END
PRINT total                      # => 55


# ════════════════════════════════════════════════════════════════
# SECTION 9: Nested WHILE
# ════════════════════════════════════════════════════════════════
PRINT "=== SECTION 9: Nested WHILE ==="

outer = 1
DO WHILE outer <= 3:
    inner = 1
    DO WHILE inner <= 3:
        IF outer == inner:
            PRINT outer
        END
        inner = inner + 1
    END
    outer = outer + 1
END
# => 1 2 3


# ════════════════════════════════════════════════════════════════
# SECTION 10: FOR IN — list iteration
# ════════════════════════════════════════════════════════════════
PRINT "=== SECTION 10: FOR IN list ==="

FOR x IN [10, 20, 30, 40, 50]:
    PRINT x
END
# => 10 20 30 40 50

sum = 0
FOR v IN [1, 2, 3, 4, 5]:
    sum = sum + v
END
PRINT sum                        # => 15


# ════════════════════════════════════════════════════════════════
# SECTION 11: FOR IN — range()
# ════════════════════════════════════════════════════════════════
PRINT "=== SECTION 11: FOR IN range ==="

FOR i IN range(5):
    PRINT i
END
# => 0 1 2 3 4

FOR i IN range(3, 8):
    PRINT i
END
# => 3 4 5 6 7

FOR i IN range(0, 10, 3):
    PRINT i
END
# => 0 3 6 9


# ════════════════════════════════════════════════════════════════
# SECTION 12: FOR IN — string iteration
# ════════════════════════════════════════════════════════════════
PRINT "=== SECTION 12: FOR IN string ==="

FOR ch IN "hello":
    PRINT ch
END
# => h e l l o

count = 0
FOR ch IN "banana":
    IF ch == "a":
        count = count + 1
    END
END
PRINT count                      # => 3


# ════════════════════════════════════════════════════════════════
# SECTION 13: FOR IN — nested
# ════════════════════════════════════════════════════════════════
PRINT "=== SECTION 13: FOR nested ==="

result = 0
FOR i IN range(1, 4):
    FOR j IN range(1, 4):
        result = result + i * j
    END
END
PRINT result                     # => 36  (1+2+3)*(1+2+3) = 36


