# test_graphics.pasta
w = WINDOW("test", 200, 120);
c = CANVAS(200, 120);

# paint a gradient + checker pattern
y = 0;
while y < 120 {
  x = 0;
  while x < 200 {
    r = (x % 256);
    g = (y % 256);
    b = ((x/10 + y/10) % 2) * 128 + ((x*y) % 128);
    PIXEL(c, x, y, r, g, b);
    x = x + 1;
  }
  y = y + 1;
}

BLIT(w, c);
WINDOW_SAVE(w, "out.ppm");
