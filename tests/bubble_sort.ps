# bubble_sort.ps
def.swap(a, i, j):
    temp = a[i]
    a[i] = a[j]
    a[j] = temp
end

def.bubble_sort(a, n):
    i = 0
    while i < n {
        j = 0
        while j < n - 1 {
            if a[j] > a[j+1] {
                swap(a, j, j+1)
            }
            j = j + 1
        }
        i = i + 1
    }
end

arr = [5,1,4,2,8,3]
PRINT("Before:", arr)
bubble_sort(arr, 6)
PRINT("After:", arr)
