/// Access the VERBOSE_DEBUG flag from main
pub fn is_verbose_debug() -> bool {
    use std::sync::atomic::{AtomicBool, Ordering};
    extern "Rust" {
        static VERBOSE_DEBUG: AtomicBool;
    }
    unsafe { VERBOSE_DEBUG.load(Ordering::Relaxed) }
}

