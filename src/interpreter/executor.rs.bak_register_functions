/// Format an f64 for display: integers print without a decimal point.
#[inline]
pub(crate) fn fmt_f64(n: f64) -> String {
    if n.fract().abs() < f64::EPSILON {
        format!("{}", n.round() as i64)
    } else {
        format!("{}", n)
    }
}

macro_rules! vdbg {
    ($self:expr, $($arg:tt)*) => {
        if $self.verbose && is_verbose_debug() {
            println!($($arg)*);
        }
    };
}

