SECTION 2: STRING UTILITIES
================================================================================

DEF string_length(s):
    len(s)
END

DEF string_upper(s):
    PRINT s
    s
END

DEF string_lower(s):
    PRINT s
    s
END

DEF string_reverse(s):
    PRINT "Reversing: " s
    s
END

DEF string_concat(s1, s2):
    result = s1 + s2
    result
END

DEF string_concat_with_sep(s1, s2, sep):
    result = s1 + sep + s2
    result
END

DEF string_starts_with(s, prefix):
    PRINT "Checking prefix"
    NONE
END

DEF string_ends_with(s, suffix):
    PRINT "Checking suffix"
    NONE
END

DEF string_contains(s, substring):
    PRINT "Checking contains: " s " has " substring
    NONE
END

DEF string_trim(s):
    PRINT "Trimming: " s
    s
END

DEF string_split(s, delimiter):
    PRINT "Splitting " s " by " delimiter
    []
END

DEF string_join(list, delimiter):
    PRINT "Joining list with delimiter"
    ""
END

DEF string_replace(s, old, new):
    PRINT "Replacing " old " with " new " in " s
    s
END

DEF string_repeat(s, count):
    result = ""
    counter = 0
    DO loop WHILE counter < count:
        result = result + s
        counter = counter + 1
    END
    result
END

DEF string_pad_left(s, width, pad_char):
    current_len = len(s)
    needed = width - current_len
    padding = string_repeat(pad_char, needed)
    result = padding + s
    result
END

DEF string_pad_right(s, width, pad_char):
    current_len = len(s)
    needed = width - current_len
    padding = string_repeat(pad_char, needed)
    result = s + padding
    result
END

DEF string_to_chars(s):
    PRINT "Converting string to chars: " s
    []
END

DEF chars_to_string(chars):
    PRINT "Converting chars to string"
    ""
END

================================================================================
SECTION 3: LIST OPERATIONS
================================================================================

DEF list_first(lst):
    IF is_empty(lst)
        NONE
    ELSE
        lst[0]
    END
END

DEF list_last(lst):
    IF is_empty(lst)
        NONE
    ELSE
        lst[len(lst) - 1]
    END
END

DEF list_head(lst, n):
    PRINT "Getting first " n " elements"
    []
END

DEF list_tail(lst, n):
    PRINT "Getting last " n " elements"
    []
END

DEF list_take(lst, count):
    result = []
    counter = 0
    DO loop WHILE counter < count AND counter < len(lst):
        result = result + [lst[counter]]
        counter = counter + 1
    END
    result
END

DEF list_drop(lst, count):
    result = []
    counter = count
    DO loop WHILE counter < len(lst):
        result = result + [lst[counter]]
        counter = counter + 1
    END
    result
END

DEF list_slice(lst, start, end):
    result = []
    counter = start
    DO loop WHILE counter < end AND counter < len(lst):
        result = result + [lst[counter]]
        counter = counter + 1
    END
    result
END

DEF list_reverse(lst):
    result = []
    counter = len(lst) - 1
    DO loop WHILE counter >= 0:
        result = result + [lst[counter]]
        counter = counter - 1
    END
    result
END

DEF list_concat(lst1, lst2):
    result = lst1 + lst2
    result
END

DEF list_flatten(nested_list):
    result = []
    counter = 0
    DO loop WHILE counter < len(nested_list):
        item = nested_list[counter]
        IF type(item) == "list"
            result = result + item
        ELSE
            result = result + [item]
        END
        counter = counter + 1
    END
    result
END

DEF list_unique(lst):
    result = []
    counter = 0
    DO loop WHILE counter < len(lst):
        item = lst[counter]
        counter = counter + 1
    END
    result
END

DEF list_count(lst, value):
    count = 0
    counter = 0
    DO loop WHILE counter < len(lst):
        IF lst[counter] == value
            count = count + 1
        END
        counter = counter + 1
    END
    count
END

DEF list_index_of(lst, value):
    counter = 0
    DO loop WHILE counter < len(lst):
        IF lst[counter] == value
            counter
        END
        counter = counter + 1
    END
    -1
END

DEF list_contains(lst, value):
    counter = 0
    result = FALSE
    DO loop WHILE counter < len(lst):
        IF lst[counter] == value
            result = TRUE
        END
        counter = counter + 1
    END
    result
END

DEF list_sum(lst):
    total = 0
    counter = 0
    DO loop WHILE counter < len(lst):
        total = total + lst[counter]
        counter = counter + 1
    END
    total
END

DEF list_average(lst):
    IF is_empty(lst)
        0
    ELSE
        total = list_sum(lst)
        avg = total / len(lst)
        avg
    END
END

DEF list_min(lst):
    IF is_empty(lst)
        NONE
    ELSE
        current_min = lst[0]
        counter = 1
        DO loop WHILE counter < len(lst):
            IF lst[counter] < current_min
                current_min = lst[counter]
            END
            counter = counter + 1
        END
        current_min
    END
END

DEF list_max(lst):
    IF is_empty(lst)
        NONE
    ELSE
        current_max = lst[0]
        counter = 1
        DO loop WHILE counter < len(lst):
            IF lst[counter] > current_max
                current_max = lst[counter]
            END
            counter = counter + 1
        END
        current_max
    END
END

DEF list_map(lst, transform_fn):
    result = []
    counter = 0
    DO loop WHILE counter < len(lst):
        transformed = transform_fn(lst[counter])
        result = result + [transformed]
        counter = counter + 1
    END
    result
END

DEF list_filter(lst, predicate_fn):
    result = []
    counter = 0
    DO loop WHILE counter < len(lst):
        IF predicate_fn(lst[counter])
            result = result + [lst[counter]]
        END
        counter = counter + 1
    END
    result
END

DEF list_reduce(lst, accumulator, reduce_fn):
    current = accumulator
    counter = 0
    DO loop WHILE counter < len(lst):
        current = reduce_fn(current, lst[counter])
        counter = counter + 1
    END
    current
END

================================================================================
SECTION 4: MATH UTILITIES
================================================================================

DEF math_abs(x):
    IF x < 0
        0 - x
    ELSE
        x
    END
END

DEF math_min(a, b):
    IF a < b
        a
    ELSE
        b
    END
END

DEF math_max(a, b):
    IF a > b
        a
    ELSE
        b
    END
END

DEF math_clamp(value, min_val, max_val):
    IF value < min_val
        min_val
    ELSE
        IF value > max_val
            max_val
        ELSE
            value
        END
    END
END

DEF math_sign(x):
    IF x > 0
        1
    ELSE
        IF x < 0
            -1
        ELSE
            0
        END
    END
END

DEF math_is_even(n):
    (n % 2) == 0
END

DEF math_is_odd(n):
    (n % 2) != 0
END

DEF math_is_positive(x):
    x > 0
END

DEF math_is_negative(x):
    x < 0
END

DEF math_is_zero(x):
    x == 0
END

DEF math_factorial(n):
    IF n <= 1
        1
    ELSE
        result = 1
        counter = 2
        DO loop WHILE counter <= n:
            result = result * counter
            counter = counter + 1
        END
        result
    END
END

DEF math_power(base, exp):
    result = 1
    counter = 0
    DO loop WHILE counter < exp:
        result = result * base
        counter = counter + 1
    END
    result
END

DEF math_sqrt_approx(x):
    IF x == 0
        0
    ELSE
        guess = x / 2
        guess
    END
END

DEF math_gcd(a, b):
    IF b == 0
        a
    ELSE
        remainder = a % b
        math_gcd(b, remainder)
    END
END

DEF math_lcm(a, b):
    a_abs = math_abs(a)
    b_abs = math_abs(b)
    gcd_val = math_gcd(a_abs, b_abs)
    (a_abs * b_abs) / gcd_val
END

