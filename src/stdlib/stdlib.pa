================================================================================
SECTION 9: CONTROL FLOW UTILITIES
================================================================================

DEF when(condition, true_fn, false_fn):
    IF condition
        true_fn()
    ELSE
        false_fn()
    END
END

DEF unless(condition, true_fn, false_fn):
    IF NOT condition
        true_fn()
    ELSE
        false_fn()
    END
END

DEF times(count, fn):
    counter = 0
    DO loop WHILE counter < count:
        fn()
        counter = counter + 1
    END
END

DEF until(condition, fn):
    DO loop WHILE NOT condition:
        fn()
    END
END

DEF repeatedly(fn):
    DO loop WHILE TRUE:
        fn()
    END
END

================================================================================
SECTION 10: PRIORITY & CONCURRENCY UTILITIES
================================================================================

DEF priority_high_over_low():
    high OVER low
END

DEF priority_urgent_over_normal():
    urgent OVER normal
END

DEF priority_critical_chain():
    critical OVER important OVER normal OVER background
END

DEF concurrent_task(name, times):
    DO task AS t FOR times:
        PRINT "Task " name " running"
    END
END

DEF concurrent_worker_pool(worker_count, task_count):
    counter = 0
    DO workers FOR worker_count:
        task_counter = 0
        DO tasks WHILE task_counter < task_count:
            PRINT "Worker executing task"
            task_counter = task_counter + 1
        END
    END
END

================================================================================
SECTION 11: VALIDATION UTILITIES
================================================================================

DEF validate_not_empty(value, field_name):
    IF is_empty(value)
        PRINT "VALIDATION ERROR: " field_name " cannot be empty"
        FALSE
    ELSE
        TRUE
    END
END

DEF validate_not_null(value, field_name):
    IF is_null(value)
        PRINT "VALIDATION ERROR: " field_name " cannot be null"
        FALSE
    ELSE
        TRUE
    END
END

DEF validate_is_number(value, field_name):
    IF NOT is_number(value)
        PRINT "VALIDATION ERROR: " field_name " must be a number"
        FALSE
    ELSE
        TRUE
    END
END

DEF validate_is_string(value, field_name):
    IF NOT is_string(value)
        PRINT "VALIDATION ERROR: " field_name " must be a string"
        FALSE
    ELSE
        TRUE
    END
END

DEF validate_is_list(value, field_name):
    IF NOT is_list(value)
        PRINT "VALIDATION ERROR: " field_name " must be a list"
        FALSE
    ELSE
        TRUE
    END
END

DEF validate_range(value, min_val, max_val, field_name):
    IF value < min_val OR value > max_val
        PRINT "VALIDATION ERROR: " field_name " must be between " min_val " and " max_val
        FALSE
    ELSE
        TRUE
    END
END

DEF validate_length(collection, min_len, max_len, field_name):
    len_val = len(collection)
    IF len_val < min_len OR len_val > max_len
        PRINT "VALIDATION ERROR: " field_name " length must be between " min_len " and " max_len
        FALSE
    ELSE
        TRUE
    END
END

================================================================================
SECTION 12: FORMATTING UTILITIES
================================================================================

DEF format_number(n, decimals):
    PRINT "Formatting number " n " with " decimals " decimals"
    str(n)
END

DEF format_currency(amount, currency_symbol):
    result = currency_symbol + str(amount)
    result
END

DEF format_percentage(value):
    result = str(value) + "%"
    result
END

DEF format_bytes(bytes):
    IF bytes < 1024
        result = str(bytes) + " B"
    ELSE
        IF bytes < 1024 * 1024
            result = str(bytes / 1024) + " KB"
        ELSE
            result = str(bytes / (1024 * 1024)) + " MB"
        END
    END
    result
END

DEF format_list(lst, separator):
    result = str(lst)
    result
END

DEF format_table(data):
    PRINT "Formatting table"
    ""
END

