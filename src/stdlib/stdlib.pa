================================================================================
PASTA STANDARD LIBRARY (stdlib.pa)
================================================================================
Version: 1.0
Date: February 26, 2026

A comprehensive backend library written in PASTA script language.
Provides utilities for string manipulation, list operations, math,
file handling, system operations, and data processing.

================================================================================
SECTION 1: UTILITY FUNCTIONS
================================================================================

DEF assert(condition, message):
    IF NOT condition
        PRINT "ASSERTION FAILED: " message
    END
END

DEF range(n):
    result = []
    counter = 0
    DO loop WHILE counter < n:
        result = result + [counter]
        counter = counter + 1
    END
    result
END

DEF repeat(value, count):
    result = []
    counter = 0
    DO loop WHILE counter < count:
        result = result + [value]
        counter = counter + 1
    END
    result
END

DEF is_empty(collection):
    len(collection) == 0
END

DEF is_null(value):
    value == NONE
END

DEF not_null(value):
    NOT is_null(value)
END

DEF identity(x):
    x
END

DEF const(value):
    lambda: value
END

