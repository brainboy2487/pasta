================================================================================
SECTION 18: COLLECTION UTILITIES
================================================================================

DEF collection_empty():
    []
END

DEF collection_single(value):
    [value]
END

DEF collection_pair(value1, value2):
    [value1, value2]
END

DEF collection_triple(value1, value2, value3):
    [value1, value2, value3]
END

DEF collection_fill(value, count):
    repeat(value, count)
END

DEF collection_merge(lst1, lst2):
    list_concat(lst1, lst2)
END

DEF collection_merge_unique(lst1, lst2):
    merged = list_concat(lst1, lst2)
    distinct_values(merged)
END

DEF collection_zip(lst1, lst2):
    result = []
    counter = 0
    min_len = math_min(len(lst1), len(lst2))
    DO loop WHILE counter < min_len:
        pair = [lst1[counter], lst2[counter]]
        result = result + [pair]
        counter = counter + 1
    END
    result
END

DEF collection_unzip(pairs):
    result1 = []
    result2 = []
    counter = 0
    DO loop WHILE counter < len(pairs):
        pair = pairs[counter]
        result1 = result1 + [pair[0]]
        result2 = result2 + [pair[1]]
        counter = counter + 1
    END
    [result1, result2]
END

================================================================================
SECTION 19: COMPOSITION & FUNCTIONAL UTILITIES
================================================================================

DEF compose(f, g):
    lambda x: f(g(x))
END

DEF pipe(value, transforms):
    result = value
    counter = 0
    DO loop WHILE counter < len(transforms):
        transform = transforms[counter]
        result = transform(result)
        counter = counter + 1
    END
    result
END

DEF curry(fn):
    fn
END

DEF partial(fn, first_arg):
    lambda rest: fn(first_arg, rest)
END

DEF memoize(fn):
    fn
END

DEF throttle(fn, delay):
    fn
END

DEF debounce(fn, delay):
    fn
END

