{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Meatball Runtime Abstraction (MRA) schema",
  "type": "object",
  "properties": {
    "spawn": {
      "type": "object",
      "properties": {
        "resources": {
          "type": "object",
          "properties": {
            "memory_mib": {"type": "integer"},
            "vcpus": {"type": "integer"},
            "disk_mib": {"type": "integer"},
            "network": {"type": "boolean"}
          },
          "required": ["memory_mib","vcpus"]
        },
        "rootfs": {"type": ["string","null"]},
        "flags": {"type": ["string","null"]}
      },
      "required": ["resources"]
    }
  }
}
